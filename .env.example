# Database (preferred names)
ODDS_DB_HOST=localhost
ODDS_DB_PORT=5432
ODDS_DB_NAME=odds_db
ODDS_DB_USER=odds_user
ODDS_DB_PASSWORD=change_me

# Legacy aliases are also supported by code:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=odds_db
# DB_USER=odds_user
# DB_PASSWORD=change_me

# Doubles filter defaults (1=skip doubles, 0=include doubles)
BETCLIC_SKIP_DOUBLES=1
BETFAN_SKIP_DOUBLES=1
IFORBET_SKIP_DOUBLES=1
ETOTO_SKIP_DOUBLES=1
TOTALBET_SKIP_DOUBLES=1
LVBET_SKIP_DOUBLES=1

# Optional single-match debug filters
IFORBET_EVENT_ID=
ETOTO_EVENT_ID=
LVBET_MATCH_ID=
